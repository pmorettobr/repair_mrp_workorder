<odoo>
    <!-- 1. Renomeia a aba Work Orders para "Ordens de Serviço" -->
    <record id="view_repair_order_form_rename_workorder" model="ir.ui.view">
        <field name="name">repair.order.form.rename.workorder</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="view_repair_order_form_inherit_workorder"/>
        <field name="arch" type="xml">
            <!-- Seleciona pela string original e renomeia -->
            <xpath expr="//page[@string='Work Orders']" position="attributes">
                <attribute name="string">Ordens de Serviço</attribute>
            </xpath>
        </field>
    </record>

    <!-- 2. Move a aba "Ordens de Serviço" para antes da aba Operations -->
    <record id="view_repair_order_form_move_workorder" model="ir.ui.view">
        <field name="name">repair.order.form.move.workorder</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="view_repair_order_form_inherit_workorder"/>
        <field name="arch" type="xml">
            <!-- Move a página que agora se chama "Ordens de Serviço" -->
            <xpath expr="//page[@string='Ordens de Serviço']" position="move">
                <xpath expr="//page[@name='operations']" position="before"/>
            </xpath>
        </field>
    </record>

    <!-- 3. Oculta a aba Operations padrão -->
    <record id="view_repair_order_form_hide_operations" model="ir.ui.view">
        <field name="name">repair.order.form.hide.operations</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='operations']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
