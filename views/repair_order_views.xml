<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================
         PASSO 1: Oculta a aba "Operations" padrão do Repair
         Usa o name="operations" que vimos no seu XML
         ======================================================== -->
    <record id="view_repair_order_form_hide_operations" model="ir.ui.view">
        <field name="name">repair.order.form.hide.operations</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='operations']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- ========================================================
         PASSO 2: Remove a aba Work Orders original (adicionada no final)
         Seleciona pelo CAMPO workorder_ids (único e confiável)
         ======================================================== -->
    <record id="view_repair_order_form_remove_original_workorder" model="ir.ui.view">
        <field name="name">repair.order.form.remove.original.workorder</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="view_repair_order_form_inherit_workorder"/>
        <field name="arch" type="xml">
            <!-- Seleciona QUALQUER página que contenha o campo workorder_ids -->
            <xpath expr="//page[.//field[@name='workorder_ids']]" position="replace"/>
        </field>
    </record>

    <!-- ========================================================
         PASSO 3: Recria a aba "Ordens de Serviço" na posição CORRETA
         Inserimos ANTES da aba "Repair Notes" (mesmo lugar da Operations)
         ======================================================== -->
    <record id="view_repair_order_form_add_workorder_position" model="ir.ui.view">
        <field name="name">repair.order.form.add.workorder.position</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="priority" eval="100"/>
        <field name="arch" type="xml">
            <!-- Insere ANTES da aba "Repair Notes" -->
            <xpath expr="//page[@string='Repair Notes']" position="before">
                <page string="Ordens de Serviço" name="work_orders_custom">
                    <field name="workorder_ids" 
                           context="{'default_repair_id': active_id}">
                        <tree decoration-success="state=='progress'"
                              decoration-danger="state=='blocked'"
                              decoration-muted="state=='done'"
                              editable="bottom">
                            <field name="name"/>
                            <field name="workcenter_id"/>
                            <field name="employee_id"/>
                            <field name="duration"/>
                            <field name="state" widget="badge"/>
                            
                            <button name="action_start"
                                    type="object"
                                    string="Iniciar"
                                    class="btn btn-success"
                                    attrs="{'invisible':[('state','!=','ready')]}"/>
                            
                            <button name="action_block"
                                    type="object"
                                    string="Bloquear"
                                    class="btn btn-danger"
                                    attrs="{'invisible':[('state','!=','progress')]}"/>
                            
                            <button name="action_done"
                                    type="object"
                                    string="Concluir"
                                    class="btn btn-secondary"
                                    attrs="{'invisible':[('state','not in',('progress','blocked'))]}"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
